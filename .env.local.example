# Airtable Personal Access Token (PAT) — required for the blog to load posts
# 1. Go to https://airtable.com/create/tokens
# 2. Create a token with scope: data.records:read
# 3. Grant access to the "Petra Education" base
# 4. Copy the token (starts with "pat_") and paste below
# 5. Restart the dev server after saving

VITE_AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxxxxxx

# Also add this to Vercel → Project Settings → Environment Variables for production
